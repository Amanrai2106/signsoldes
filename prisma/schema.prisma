// datasource and generator
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// models
model ContactSubmission {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  phone        String
  countryCode  String
  category     String
  subCategory  String
  subject      String?
  message      String
  contacted    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Service {
  id                Int                  @id @default(autoincrement())
  title             String
  description       String
  details           String?
  relatedProjectIds String?
  subCategories     ServiceSubCategory[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model ServiceSubCategory {
  id        Int      @id @default(autoincrement())
  key       String
  title     String
  image     String
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id])
}

model ProjectCategory {
  id                 String                @id
  title              String
  description        String
  src                String
  color              String?
  relatedServiceIds  String?
  subCategories      ProjectSubCategory[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model ProjectSubCategory {
  id        Int              @id @default(autoincrement())
  key       String
  title     String
  image     String
  projectId String
  project   ProjectCategory  @relation(fields: [projectId], references: [id])
}

model Post {
  id            String   @id
  title         String
  description   String
  image         String
  categoryId    String
  subCategoryId String
  type          String
  
  // New fields for rich project pages
  client        String?
  location      String?
  year          String?
  scope         String?
  
  challengeTitle       String?
  challengeDescription String?
  challengeItems       String? // JSON string of string[]
  
  solutionTitle       String?
  solutionDescription String?
  solutionItems       String? // JSON string of { label: string, value: string }[]
  
  galleryImages        String? // JSON string of string[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model News {
  id        String   @id
  title     String
  slug      String   @unique
  excerpt   String
  cover     String
  category  String
  type      String   @default("news") // "news" or "idea"
  tags      String?  // JSON string
  topic     String?  @default("none")
  content   String   // HTML
  status    String   @default("published")
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
