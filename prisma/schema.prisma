// datasource and generator
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// models
model ContactSubmission {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  phone        String
  countryCode  String
  category     String
  subCategory  String
  subject      String?
  message      String
  createdAt    DateTime @default(now())
}

model Service {
  id                Int                  @id @default(autoincrement())
  title             String
  description       String
  details           Json?
  relatedProjectIds Json?
  subCategories     ServiceSubCategory[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model ServiceSubCategory {
  id        Int      @id @default(autoincrement())
  key       String
  title     String
  image     String
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id])
}

model ProjectCategory {
  id                 String                @id
  title              String
  description        String
  src                String
  color              String?
  relatedServiceIds  Json?
  subCategories      ProjectSubCategory[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model ProjectSubCategory {
  id        Int              @id @default(autoincrement())
  key       String
  title     String
  image     String
  projectId String
  project   ProjectCategory  @relation(fields: [projectId], references: [id])
}

model Post {
  id            String   @id
  title         String
  description   String
  image         String
  categoryId    String
  subCategoryId String
  type          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
